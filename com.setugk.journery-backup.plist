<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.setugk.journery-backup</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/setugk/.journery/backup_journery_mac.sh</string>
    </array>

    <!-- Run at 2:00am daily -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Also run once on login (catches missed runs while Mac was asleep) -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/setugk/.journery/backup.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/setugk/.journery/backup.log</string>
</dict>
</plist>
